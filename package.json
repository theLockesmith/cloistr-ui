{
  "name": "@cloistr/ui",
  "version": "0.17.0",
  "description": "Shared React UI components for Cloistr applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./auth": {
      "import": "./dist/auth/index.js",
      "types": "./dist/auth/index.d.ts"
    },
    "./components": {
      "import": "./dist/components/index.js",
      "types": "./dist/components/index.d.ts"
    },
    "./styles": {
      "import": "./dist/styles/index.css",
      "types": "./dist/styles/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "build": "npm run typecheck && tsc && cp -r src/styles dist/",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@cloistr/auth": "^0.2.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@cloistr/auth": "^0.2.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "cloistr",
    "nostr",
    "react",
    "ui",
    "components"
  ],
  "author": "Coldforge",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://git.aegis-hq.xyz/coldforge/cloistr-ui.git"
  },
  "publishConfig": {
    "@cloistr:registry": "https://git.aegis-hq.xyz/api/v4/projects/59/packages/npm/"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "qrcode": "^1.5.4"
  }
}
